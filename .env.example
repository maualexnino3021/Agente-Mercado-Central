# Copia este archivo a .env y completa tus claves reales.
# NUNCA subas el archivo .env real a un repositorio público.

# Proveedor del LLM de chat: "openai" (por defecto) o "anthropic"
LLM_PROVIDER=openai

# --- OpenAI ---
# Requerida SIEMPRE: se usa para el LLM de chat (si LLM_PROVIDER=openai) y,
# de forma OBLIGATORIA en cualquier caso, para generar los embeddings del RAG.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic (alternativa solo para el LLM de chat) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# --- Parámetros de chunking / retrieval ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVER_TOP_K=4

# --- Parámetros de negocio ---
DIAS_ALERTA_VENCIMIENTO=30
